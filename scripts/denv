#!/bin/bash
# denv — start or attach to a Dockerized development environment
set -e

IMAGE_REMOTE="ghcr.io/zsombor-flds/denv"
IMAGE_LOCAL="denv"
CONTAINER_NAME="denv"

usage() {
  echo "Usage: denv [command]"
  echo ""
  echo "Commands:"
  echo "  (none)    Start or attach to the dev environment (remote image)"
  echo "  local     Start or attach using a locally-built image"
  echo "  stop      Stop the running container"
  echo "  status    Show container status"
  echo ""
  echo "Install:"
  echo "  curl -fsSL https://raw.githubusercontent.com/zsombor-flds/denv/main/scripts/denv \\"
  echo "    | sudo tee /usr/local/bin/denv > /dev/null && sudo chmod +x /usr/local/bin/denv"
}

check_docker() {
  if ! command -v docker &> /dev/null; then
    echo "Error: docker is not installed." >&2
    echo "Install it first: https://docs.docker.com/engine/install/" >&2
    exit 1
  fi
}

container_running() {
  docker ps --format '{{.Names}}' | grep -q "^${CONTAINER_NAME}$"
}

start_or_attach() {
  local image="$1"

  # Persistent state dirs
  local histfile="$HOME/denv/.docker_zsh_history"
  local workspace="$HOME/workspace"
  local gitconfig="$HOME/.gitconfig"
  local ssh_dir="$HOME/.ssh"
  local tmux_dir="$HOME/denv/tmux"

  mkdir -p "$(dirname "$histfile")" "$tmux_dir" "$workspace"
  touch "$histfile"

  if container_running; then
    echo "Container '${CONTAINER_NAME}' is already running. Attaching..."
    docker exec -it "$CONTAINER_NAME" zsh
  else
    echo "Starting denv (image: $image)..."
    docker run -it \
      --rm \
      --name "$CONTAINER_NAME" \
      --network=host \
      --privileged \
      --log-driver=json-file \
      --log-opt max-size=10m \
      --log-opt max-file=3 \
      -v "$workspace":/workspace \
      -v "$histfile":/root/.zsh/history \
      -v "$gitconfig":/root/.gitconfig:ro \
      -v "$ssh_dir":/root/.ssh:ro \
      -v "$tmux_dir":/root/.tmux/resurrect \
      -v /var/run/docker.sock:/var/run/docker.sock \
      "$image" \
      zsh
  fi
}

# --- Main ---

check_docker

case "${1:-}" in
  ""|start)
    start_or_attach "$IMAGE_REMOTE"
    ;;
  local)
    start_or_attach "$IMAGE_LOCAL"
    ;;
  stop)
    if container_running; then
      docker stop "$CONTAINER_NAME"
      echo "Stopped."
    else
      echo "No running container."
    fi
    ;;
  status)
    if container_running; then
      docker ps --filter "name=^${CONTAINER_NAME}$"
    else
      echo "Not running."
    fi
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "Unknown command: $1" >&2
    usage >&2
    exit 1
    ;;
esac
